[MASTER]

[MESSAGES CONTROL]
# Disable complexity metric warnings that would require major logic refactoring,
# but keep all docstring, line length, type, naming, unused variables, and style warnings active.
disable=
    too-many-locals,
    too-many-instance-attributes,
    too-many-arguments,
    too-many-positional-arguments

[FORMAT]
max-line-length=100

[SIMILARITIES]
# Test fixtures naturally repeat short setup blocks. Keep duplicate detection
# for substantial copies without failing on routine unittest scaffolding.
min-similarity-lines=15
